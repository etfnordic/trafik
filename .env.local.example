TRAFIKLAB_REALTIME_API_KEY=your-gtfs-sweden-3-realtime-key-here
TRAFIKLAB_STATIC_API_KEY=your-gtfs-sweden-3-static-key-here

# Optional: one realtime key per operator. These override the global realtime key for that operator.
TRAFIKLAB_REALTIME_API_KEY_SL=your-sl-realtime-key-here
TRAFIKLAB_REALTIME_API_KEY_UL=your-ul-realtime-key-here
TRAFIKLAB_REALTIME_API_KEY_SKANE=your-skane-realtime-key-here
